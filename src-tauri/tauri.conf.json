{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kindle Create",
  "version": "0.1.0",
  "identifier": "com.user.kindlecreate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kindle Create",
        "width": 1120,
        "height": 860,
        "minWidth": 920,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [],
    "resources": ["../scripts/pdf_page_tool.swift"]
  }
}
